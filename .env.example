# NeuraQuire Configuration
# Copy this file to .env and fill in your values

# Debug mode (set to true for verbose logging)
NEURAQUIRE_DEBUG=false

# LLM Configuration (MiMo)
NEURAQUIRE_LLM_MODEL=mimo-v2.5
NEURAQUIRE_LLM_BASE_URL=https://api.xiaomimimo.com/v1

# Vision Model (Gemini) - Get free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Embedding Model
NEURAQUIRE_EMBEDDING_MODEL=all-MiniLM-L12-v2

# Security Limits
NEURAQUIRE_MAX_UPLOAD_MB=50
NEURAQUIRE_RATE_LIMIT=10
NEURAQUIRE_FILE_TTL=3600
NEURAQUIRE_CHUNK_SIZE=500
